# Application
NODE_ENV=development
PORT=8001
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/freshcart?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-this-to-another-strong-random-secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Upload
UPLOAD_DIR=./uploads

# CORS (alias of FRONTEND_URL, comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173